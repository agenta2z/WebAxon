# WebAxon Browser Sidecar Configuration
# Copy this file to .env and customize as needed

# Server settings
# Use 0.0.0.0 to accept connections from Docker containers (via host.docker.internal)
WEBAXON_HOST=0.0.0.0
WEBAXON_PORT=18800

# Browser settings
WEBAXON_HEADLESS=false
WEBAXON_CHROME_VERSION=
WEBAXON_BACKEND=playwright

# Agent settings
WEBAXON_AGENT_TYPE=DefaultAgent
WEBAXON_MAX_STEPS=50
WEBAXON_AGENT_TIMEOUT=300

# Workspace settings
WEBAXON_WORKSPACE=~/.webaxon/workspace

# Debug settings
WEBAXON_DEBUG=false
WEBAXON_SYNC_AGENT=true

# -----------------------------------------------------------------------------
# OpenClaw Gateway Integration (Optional)
# -----------------------------------------------------------------------------
# If set, the sidecar will connect to OpenClaw Gateway as a browser-capable node.
# This allows OpenClaw to automatically route browser requests to WebAxon.

# Gateway WebSocket URL (e.g., ws://127.0.0.1:18789 or ws://host.docker.internal:18789)
# OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# Gateway authentication token (must match OPENCLAW_GATEWAY_TOKEN in OpenClaw)
# OPENCLAW_GATEWAY_TOKEN=your-gateway-token
